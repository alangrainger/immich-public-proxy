{
  "ipp": {
    "responseHeaders": {
      "Cache-Control": "public, max-age=2592000",
      "Access-Control-Allow-Origin":  "*"
    },
    "downloadOriginalPhoto": true,
    "downloadedFilename": 2,
    "allowDownloadAll": 0,
    "downloadFromImmichConcurrencyLimit": 20,
    "allowSlugLinks": true,
    "showHomePage": true,
    "showMetadata": {
      "description": {
        "caption": false,
        "sidebar": false
      },
      "exif": {
        "enabled": false,
        "dateTimeOriginal": true,
        "fileName": true,
        "dimensions": true,
        "fileSize": true,
        "make": true,
        "model": true,
        "lensModel": true,
        "exposureTime": true,
        "iso": true,
        "fNumber": true,
        "focalLength": true
      },
      "location": {
        "enabled": false,
        "city": true,
        "state": true,
        "country": true,
        "gps": true,
        "webLink": true
      }
    },
    "customInvalidResponse": false,
    "gallery": {
      "singleImage": false,
      "singleItemAutoOpen": true,
      "showTitle": true,
      "showDescription": false,
      "groupByDate": false
    },
    "lightbox": {
      "showArrows": true,
      "showDownload": true,
      "mobileArrows": false
    }
  }
}
