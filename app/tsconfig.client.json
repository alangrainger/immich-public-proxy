{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "public/js",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "inlineSourceMap": true,
    "inlineSources": true
  },
  "include": [
    "src/client/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
